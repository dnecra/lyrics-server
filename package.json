{
  "name": "lyrics-smtc",
  "version": "1.0.0",
  "description": "Lyrics Server powered by SMTC",
  "main": "bundle.js",
  "bin": "bundle.js",
  "scripts": {
    "dev": "npm run build:smtc:helper && node server.js",
    "build:smtc:helper": "dotnet publish tools/smtc-bridge-cs/SmtcBridge.csproj -c Release -r win-x64 --self-contained -o smtc-helper/x64",
    "build": "node scripts/build-smtc.js x64",
    "build:all": "node scripts/build-smtc.js x64",
    "build:x64": "node scripts/build-smtc.js x64",
    "build:gui": "node scripts/build-smtc.js x64 --no-console",
    "build:gui:x64": "node scripts/build-smtc.js x64 --no-console",
    "build:bundle": "esbuild server.js --bundle --platform=node --outfile=bundle.js --external:kuromoji"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "es-hangul": "^2.3.8",
    "esbuild": "^0.27.3",
    "hono": "^4.12.2",
    "kuromoji": "^0.1.2",
    "kuroshiro": "^1.2.0",
    "kuroshiro-analyzer-kuromoji": "^1.1.0",
    "pinyin-pro": "^3.28.0",
    "tinyld": "^1.3.4",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "pkg": "^5.8.1"
  },
  "pkg": {
    "assets": [
      "public/**/*",
      "node_modules/kuromoji/dict/**/*"
    ]
  }
}
